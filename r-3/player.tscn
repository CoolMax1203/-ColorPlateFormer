[sub_resource type="GDScript" id="GDScript_4flbx"]
resource_name = "PlayerScript"
script/source = "extends CharacterBody2D

class_name Player 
@onready var player_collision_shape: CollisionShape2D = $PlayerCollisionShape
@onready var player: CharacterBody2D = $\".\"
@onready var animation_player: AnimationPlayer = $AnimationPlayer
@onready var sprite_2d: Sprite2D = $Sprite2D

const SPEED = 120.0
const JUMP_VELOCITY = -300.0
var can_jump:bool=false
func _ready() -> void:
	$\"../Timer\".stop()
func _physics_process(delta: float) -> void:
	$\"../Timer\".stop()
	var direction := Input.get_axis(\"ui_left\", \"ui_right\")
	# Add the gravity.
	if not is_on_floor():
		if can_jump==false and $\"../Timer\".paused==true:
			print(\"ssw\")
			$\"../Timer\".start(.4)
			can_jump=true
			
		velocity += get_gravity() * delta
		
	else:
		can_jump=false
	
	if Input.is_action_just_pressed(\"ui_up\") and (is_on_floor() or can_jump==true and $\"../Timer\".paused==true):
		velocity.y = JUMP_VELOCITY
		animation_player.play(\"Jump\")
		$\"../Timer\".stop()
		can_jump=false


		
	if Input.is_action_just_pressed(\"ui_accept\"):
		if player.collision_mask==2:
			player.collision_mask=1
		elif player.collision_mask==1:
			player.collision_mask=2
	# Get the input direction and handle the movement/deceleration.
	# As good practice, you should replace UI actions with custom gameplay actions.
	if direction:
		if direction==1:
			$Sprite2D.flip_h=false
		else:
			$Sprite2D.flip_h=true
		animation_player.play(\"Runing\")
		velocity.x = direction * SPEED
	else:
		if not Input.is_action_just_pressed(\"ui_up\") and is_on_floor():
			animation_player.play(\"Idle\")
		velocity.x = move_toward(velocity.x, 0, SPEED)
	move_and_slide()


func _on_timer_timeout() -> void:
	can_jump=false
	print(\"sss\")
"

